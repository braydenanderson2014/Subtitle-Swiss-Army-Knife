{
  "_description": "Aggressive scene-release cleanup. Use when filenames include many release flags and language tags.",
  "_example_movie": "Movie.Name.2023.1080p.BluRay.REPACK.MULTI.x265.DDP5.1-GROUP -> Movie Name 2023",
  "_example_tv": "Series.Name.S02E07.2160p.WEB-DL.HDR10.ATMOS.PROPER-GROUP -> Series Name - S02E07",
  "movie_name": {
    "normalize_separators": true,
    "strip_bracketed": true,
    "cutoff_tokens": [
      "\\bUHD\\b",
      "\\b2160p\\b",
      "\\b1080p\\b",
      "\\b720p\\b",
      "\\bWEB[-_. ]?DL\\b",
      "\\bWEB[-_. ]?Rip\\b",
      "\\bBlu[-_. ]?Ray\\b",
      "\\bBRRip\\b",
      "\\bBDRip\\b",
      "\\bDVDRip\\b",
      "\\bHDRip\\b",
      "\\bREMUX\\b",
      "\\bPROPER\\b",
      "\\bREPACK\\b",
      "\\bEXTENDED\\b",
      "\\bUNRATED\\b",
      "\\bMULTI\\b",
      "\\bDUAL[-_. ]?AUDIO\\b",
      "\\bHDR10(?:\\+)?\\b",
      "\\bDolby[-_. ]?Vision\\b",
      "\\bAtmos\\b",
      "\\bTrueHD\\b",
      "\\bDTS[-_. ]?HD\\b",
      "\\bx264\\b",
      "\\bx265\\b",
      "\\bHEVC\\b",
      "\\bAAC\\b",
      "\\bDDP?5\\.1\\b",
      "\\bYTS\\b",
      "\\bRARBG\\b",
      "\\bEVO\\b",
      "\\bFGT\\b"
    ],
    "cleanup_regex": [
      {
        "pattern": "[-_]+",
        "replace": " "
      },
      {
        "pattern": "\\b(AMZN|NF|HMAX|DSNP)\\b",
        "replace": ""
      },
      {
        "pattern": "\\s{2,}",
        "replace": " "
      }
    ]
  },
  "tv_name": {
    "template": "{clean_name} - {season_episode}",
    "normalize_separators": true,
    "strip_bracketed": true,
    "patterns": [
      {
        "pattern": "(?i)S(?P<season>\\d{1,2})E(?P<episode>\\d{1,3})"
      },
      {
        "pattern": "(?i)(?P<season>\\d{1,2})x(?P<episode>\\d{1,3})"
      },
      {
        "pattern": "(?i)Season[ ._-]?(?P<season>\\d{1,2})[ ._-]*Episode[ ._-]?(?P<episode>\\d{1,3})"
      }
    ],
    "cutoff_tokens": [
      "\\bUHD\\b",
      "\\b2160p\\b",
      "\\b1080p\\b",
      "\\b720p\\b",
      "\\bWEB[-_. ]?DL\\b",
      "\\bWEB[-_. ]?Rip\\b",
      "\\bBlu[-_. ]?Ray\\b",
      "\\bPROPER\\b",
      "\\bREPACK\\b",
      "\\bEXTENDED\\b",
      "\\bMULTI\\b",
      "\\bHDR10(?:\\+)?\\b",
      "\\bDolby[-_. ]?Vision\\b",
      "\\bAtmos\\b",
      "\\bx264\\b",
      "\\bx265\\b",
      "\\bHEVC\\b",
      "\\bAAC\\b",
      "\\bDDP?5\\.1\\b",
      "\\bYTS\\b",
      "\\bRARBG\\b"
    ],
    "cleanup_regex": [
      {
        "pattern": "[-_]+",
        "replace": " "
      },
      {
        "pattern": "\\b(AMZN|NF|HMAX|DSNP)\\b",
        "replace": ""
      },
      {
        "pattern": "\\s{2,}",
        "replace": " "
      }
    ]
  }
}
