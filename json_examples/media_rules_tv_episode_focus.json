{
  "_description": "TV-focused preset with extra episode pattern support and strong stripping of source tags like BluRay/WEB/codec info.",
  "_example_tv_1": "Show.Name.S01E02.1080p.BluRay.x265-GROUP -> Show Name - S01E02",
  "_example_tv_2": "Show Name 2x07 WEB-DL AAC -> Show Name - S02E07",
  "movie_name": {
    "normalize_separators": true,
    "strip_bracketed": true,
    "cutoff_tokens": [
      "\\b2160p\\b",
      "\\b1080p\\b",
      "\\b720p\\b",
      "\\bBlu[-_. ]?Ray\\b",
      "\\bWEB[-_. ]?DL\\b",
      "\\bWEB[-_. ]?Rip\\b",
      "\\bx264\\b",
      "\\bx265\\b",
      "\\bHEVC\\b",
      "\\bAAC\\b",
      "\\bDDP?5\\.1\\b",
      "\\bYTS\\b",
      "\\bRARBG\\b"
    ],
    "cleanup_regex": [
      {
        "pattern": "[-_]+",
        "replace": " "
      }
    ]
  },
  "tv_name": {
    "template": "{clean_name} - {season_episode}",
    "normalize_separators": true,
    "strip_bracketed": true,
    "patterns": [
      {
        "pattern": "(?i)S(?P<season>\\d{1,2})E(?P<episode>\\d{1,3})"
      },
      {
        "pattern": "(?i)(?P<season>\\d{1,2})x(?P<episode>\\d{1,3})"
      },
      {
        "pattern": "(?i)Season[ ._-]?(?P<season>\\d{1,2})[ ._-]*Episode[ ._-]?(?P<episode>\\d{1,3})"
      },
      {
        "pattern": "(?i)(?P<season>\\d{1,2})[ ._-]*Ep(?:isode)?[ ._-]?(?P<episode>\\d{1,3})"
      }
    ],
    "cutoff_tokens": [
      "\\b2160p\\b",
      "\\b1080p\\b",
      "\\b720p\\b",
      "\\bBlu[-_. ]?Ray\\b",
      "\\bBRRip\\b",
      "\\bBDRip\\b",
      "\\bWEB[-_. ]?DL\\b",
      "\\bWEB[-_. ]?Rip\\b",
      "\\bHDRip\\b",
      "\\bx264\\b",
      "\\bx265\\b",
      "\\bHEVC\\b",
      "\\bAVC\\b",
      "\\bAAC\\b",
      "\\bDDP?5\\.1\\b",
      "\\bYTS\\b",
      "\\bRARBG\\b"
    ],
    "cleanup_regex": [
      {
        "pattern": "[-_]+",
        "replace": " "
      },
      {
        "pattern": "\\s{2,}",
        "replace": " "
      }
    ]
  }
}
